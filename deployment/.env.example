# StarMake ERP 部署环境变量
# 复制此文件为 .env 并修改

# 站点名称（域名或IP）
SITE_NAME=erp.local
# MariaDB root 密码
MYSQL_ROOT_PASSWORD=StArMaKe2024!
# Frappe 管理员密码
ADMIN_PASSWORD=admin123
# 数据库名
DB_NAME=starmake_erp

# 时区
TZ=Asia/Shanghai

# 备份路径（宿主机路径）
BACKUP_PATH=./backups

# ERPNext 版本
ERPNEXT_VERSION=v17
FRAPPE_VERSION=v17
